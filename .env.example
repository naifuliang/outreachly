# Outreachly — environment template. Copy to `.env` and fill in. NEVER commit `.env`.

# --- Core ---
APP_ENV=dev
DEFAULT_LOCALE=en            # en | zh
# DB_PATH=./data/crm.sqlite  # optional override

# --- LLM: ICP generation & copywriting ---
# https://console.anthropic.com/
ANTHROPIC_API_KEY=

# --- Google Places API: lead discovery (Google Maps) ---
# https://developers.google.com/maps/documentation/places/web-service/get-api-key
GOOGLE_PLACES_API_KEY=

# --- Unipile: LinkedIn discovery/DM, Email send, unified inbox ---
# https://developer.unipile.com/  (DSN is your workspace base URL incl. port)
UNIPILE_DSN=
UNIPILE_API_KEY=

# --- X (Twitter) API v2: discovery + DM ---
# https://developer.x.com/  (app bearer token; DM send adds user-context OAuth in P5)
X_BEARER_TOKEN=

# --- Hunter.io: email finding ---
# https://hunter.io/api-keys
HUNTER_API_KEY=

# --- NeverBounce: email verification ---
# https://app.neverbounce.com/settings/api
NEVERBOUNCE_API_KEY=
